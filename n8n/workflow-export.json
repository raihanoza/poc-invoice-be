        "emailFormat": "html",
        "html": "=<div style=\"font-family:Arial,sans-serif;font-size:14px;white-space:pre-line\">{{ $('Build message context').item.json.messageContent }}</div><p style=\"font-family:Arial,sans-serif;font-size:14px\">Lihat invoice: <a href=\"{{ $('Build message context').item.json.shareUrl }}\">{{ $('Build message context').item.json.shareUrl }}</a></p>",
        "options": {
