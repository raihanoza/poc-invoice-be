# ─────────────────────────────────────────────────────────────────────────────
# Deployment env for docker-compose (Postgres + backend + n8n) on the Droplet.
# Copy to `.env` on the server:  cp .env.deploy.example .env  then fill the blanks.
# Compose auto-reads `.env` in this folder. Do NOT commit the filled-in .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- Postgres (lives inside the stack; pick any strong password) ---
POSTGRES_USER=invoice
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=poc_invoice

# --- Backend ---
# Shared secret between the API and n8n (x-internal-key). Generate one:
#   openssl rand -hex 24
INTERNAL_API_KEY=change-me-random-hex
BUSINESS_NAME=Your Business Name

# Public base URL of the FRONTEND (Vercel) — used to build invoice share links.
# e.g. https://poc-invoice-frontend.vercel.app
WEB_PUBLIC_URL=https://your-frontend.vercel.app

# --- Email (SMTP via Nodemailer). For Gmail use an App Password, not your login. ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=you@gmail.com

# --- WhatsApp gateway. Leave token blank to disable WA sending. ---
# 'host.docker.internal' points at the Droplet host (extra_hosts is set in
# docker-compose.yml), so this assumes the WA gateway runs on the host at :3002.
# If you instead run the gateway as its own compose service, use its service name
# here, e.g. http://wa-gateway:3002/whatsapp/send-message.
WHATSAPP_SERVICE_URL=http://host.docker.internal:3002/whatsapp/send-message
WHATSAPP_SERVICE_IMAGE_URL=http://host.docker.internal:3002/whatsapp/send-message-image
WHATSAPP_SERVICE_TOKEN=
WHATSAPP_SESSION_ID=

# --- AI (Groq) — drafts reminder messages. Blank = fall back to plain template. ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Reminder config ---
REMINDER_DAYS_BEFORE_DUE=3

# --- n8n ---
# Stable key so saved credentials survive restarts. Generate one:
#   openssl rand -hex 24
N8N_ENCRYPTION_KEY=change-me-random-hex
# Your Droplet's public IP (or domain if you add one later), e.g. 159.65.1.23
N8N_HOST=YOUR_DROPLET_IP
