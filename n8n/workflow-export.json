    {
      "parameters": {
        "jsCode": "const res=$input.first().json; const list=Array.isArray(res.data)?res.data:(Array.isArray(res)?res:[]); return list.map((inv)=>({ json: inv }));"
      },
      "id": "57637042-c204-42bd-9775-42329ce819db",
      "name": "Split invoices",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1104,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const MS=86400000; const today=new Date(); today.setUTCHours(0,0,0,0); return $input.all().map((item)=>{ const inv=item.json; const due=new Date(inv.dueDate); due.setUTCHours(0,0,0,0); const diff=Math.round((due.getTime()-today.getTime())/MS); const overdue=diff<0; return { json: { ...inv, tone: overdue?'firm':'friendly', daysOverdue: overdue?Math.abs(diff):0, daysUntilDue: overdue?0:diff } }; });"
      },
      "id": "f4d6b739-2dcf-46c1-bb82-a8c159592494",
      "name": "Compute tone & days",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -880,
        192
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.GROQ_API_KEY }}"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama-3.3-70b-versatile', max_tokens: 400, temperature: 0.7, messages: [ { role: 'system', content: 'Kamu adalah asisten yang menulis pesan pengingat pembayaran invoice untuk sebuah bisnis kecil.\\n\\nTulis SATU pesan pengingat singkat (maksimal 80 kata) dalam Bahasa Indonesia, dengan ketentuan:\\n- Jika tone = friendly: nada ramah, sopan, tidak menekan, mengingatkan jatuh tempo yang akan datang.\\n- Jika tone = firm: nada lebih tegas dan profesional (bukan kasar), menekankan invoice sudah lewat jatuh tempo dan perlu segera dibayar.\\n- Sebutkan nomor invoice, jumlah tagihan, dan tanggal jatuh tempo.\\n- Jangan gunakan salam pembuka formal yang panjang, langsung ke inti pesan.\\n- Output HANYA teks pesan, tanpa penjelasan tambahan, tanpa markdown.' }, { role: 'user', content: 'Data:\\n- Nama client: ' + $json.client.name + '\\n- Nomor invoice: ' + $json.invoiceNo + '\\n- Jumlah tagihan: Rp ' + $json.grandTotal + '\\n- Tanggal jatuh tempo: ' + $json.dueDate + '\\n- Tone: ' + $json.tone + '\\n- Hari terlambat (jika ada): ' + ($json.daysOverdue || 0) } ] }) }}",
        "options": {}
      },
      "id": "d58aad97-199f-4bad-8515-0c1fc2483c55",
      "name": "Draft message (Groq)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -656,
        192
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const inv=$('Compute tone & days').item.json; const ai=$json; const text=(ai&&ai.choices&&ai.choices[0]&&ai.choices[0].message&&ai.choices[0].message.content)?ai.choices[0].message.content:''; const base=$env.WEB_PUBLIC_URL||''; return { json: { invoiceId: inv.id, invoiceNo: inv.invoiceNo, grandTotal: inv.grandTotal, dueDate: inv.dueDate, channel: inv.client.reminderChannel, email: inv.client.email, whatsapp: inv.client.whatsappNumber, clientName: inv.client.name, tone: inv.tone, daysOverdue: inv.daysOverdue, shareToken: inv.shareToken, shareUrl: base + '/invoice/' + inv.shareToken, messageContent: text } };"
      },
      "id": "71051f4c-f040-4b30-9964-ce8086972e26",
      "name": "Build message context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
