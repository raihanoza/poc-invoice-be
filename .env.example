# Database — replace with a real PostgreSQL connection string (Neon/Supabase/local)
DATABASE_URL=postgres://user:pass@localhost:5432/poc_invoice

# Backend
PORT=3001
INTERNAL_API_KEY=

# Business identity (shown on the invoice PDF and in sent messages)
BUSINESS_NAME=Your Business Name

# Public web base URL — used to build share links (e.g. {WEB_PUBLIC_URL}/invoice/{token})
WEB_PUBLIC_URL=http://localhost:3000

# Email (SMTP via Nodemailer) — used for sending invoices and reminders.
# For Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_USER=you@gmail.com, and EMAIL_PASS
# must be a Gmail App Password (https://myaccount.google.com/apppasswords), not
# your normal login. EMAIL_PORT defaults to 587; use 465 for implicit TLS.
# EMAIL_FROM is optional and falls back to EMAIL_USER.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# WhatsApp (waapi transporindo) — body { message, numbers, apiKey }
# WHATSAPP_SERVICE_TOKEN holds the apiKey
WHATSAPP_SERVICE_URL=https://waapi.transporindo.com/whatsapp/send-message
WHATSAPP_SERVICE_TOKEN=

# AI (Groq) — drafts reminder messages, used by n8n AND by the backend's immediate
# on-create reminder. If unset, the backend falls back to a simple template.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Reminder config — used in a later phase
REMINDER_DAYS_BEFORE_DUE=3

# Frontend (apps/web) — added in a later phase
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
